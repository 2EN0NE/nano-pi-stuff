{
	"name": "mitsupi",
	"version": "1.6.0",
	"description": "zenone's pi coding agent commands, skills, extensions, and themes",
	"repository": {
		"type": "git",
		"url": "https://github.com/2EN0NE/nano-pi-stuff.git"
	},
	"readme": "README.md",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi-skill",
		"pi-theme"
	],
	"pi": {
		"extensions": [
			"./extensions/meta/pi-logger",
			"./extensions/tui/session-tree-label",
			"./extensions",
			"!extensions/goal.ts"
		],
		"skills": [
			"./skills"
		],
		"themes": [
			"./themes"
		],
		"prompts": [
			"./prompts"
		]
	},
	"dependencies": {
		"diff": "^8.0.2",
		"js-tiktoken": "^1.0.21"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/js-yaml": "^4.0.9",
		"@zenone/pi-logger": "file:extensions/meta/pi-logger",
		"@zenone/pi-selector": "file:extensions/meta/selector",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"js-yaml": "^5.2.1",
		"lint-staged": "^17.0.7",
		"prettier": "^3.9.5",
		"tsx": "^4.23.1",
		"vitest": "^4.1.10"
	},
	"scripts": {
		"prepare": "husky",
		"lint": "eslint .",
		"lint:staged": "lint-staged",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --noEmit",
		"semgrep": "semgrep --config .semgrep.yml --exclude 'node_modules/**' --exclude '.pi/**' --exclude '.git/**' --metrics=off --no-git-ignore",
		"semgrep:ci": "npm run semgrep -- --severity ERROR --severity WARNING",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ci": "CI=true vitest run --reporter default --reporter junit",
		"e2e": "bash test/scripts/run-e2e.sh",
		"check": "npm run format:check && npm run typecheck && npm run semgrep:ci && npm run lint"
	},
	"lint-staged": {
		"*.{js,mjs,cjs}": "eslint --fix",
		"*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": "prettier --write"
	}
}
