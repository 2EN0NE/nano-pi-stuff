{
  "name": "mitsupi",
  "version": "1.6.0",
  "description": "zenone's pi coding agent commands, skills, extensions, and themes",
  "repository": {
    "type": "git",
    "url": "https://github.com/2EN0NE/nano-pi-stuff.git"
  },
  "readme": "README.md",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-theme"
  ],
  "pi": {
    "extensions": [
      "./extensions/pi-logger",
      "./extensions",
      "!extensions/goal.ts"
    ],
    "skills": [
      "./skills"
    ],
    "themes": [
      "./themes"
    ],
    "prompts": [
      "./commands"
    ]
  },
  "dependencies": {
    "diff": "^8.0.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:staged": "lint-staged",
    "lint:fix": "eslint . --fix"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  }
}
